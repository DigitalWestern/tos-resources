#!/bin/bash
#
# Pre-push hook: scans outgoing commits for secrets, sensitive data,
# and broken asset references before allowing a push.
#
# To bypass intentionally:  git push --no-verify
#

# ── Colors for output ──────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

BLOCKED=0

# ── Determine which commits are being pushed ───────────────────────
# Git passes (remote name, remote URL) as args, and feeds lines of
# (local ref, local sha, remote ref, remote sha) on stdin.
# We collect every file changed across all commits being pushed.

CHANGED_FILES=""

while read local_ref local_sha remote_ref remote_sha; do
    # If remote_sha is all zeros, this is a new branch — compare against
    # the point it diverged from main (or the root if main doesn't exist).
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        base=$(git merge-base main "$local_sha" 2>/dev/null || echo "")
        if [ -z "$base" ]; then
            # Brand new repo or no main branch — scan all files in the push
            range="$local_sha"
        else
            range="$base..$local_sha"
        fi
    else
        range="$remote_sha..$local_sha"
    fi

    # Collect changed file paths (only files that exist, not deletions)
    FILES=$(git diff --name-only --diff-filter=d "$range" 2>/dev/null)
    if [ -z "$FILES" ] && [ -n "$range" ]; then
        # Fallback for new branches: list all files in the commit
        FILES=$(git ls-tree -r --name-only "$local_sha" 2>/dev/null)
    fi
    CHANGED_FILES="$CHANGED_FILES $FILES"
done

# Deduplicate
CHANGED_FILES=$(echo "$CHANGED_FILES" | tr ' ' '\n' | sort -u | grep -v '^$')

if [ -z "$CHANGED_FILES" ]; then
    exit 0
fi

# ══════════════════════════════════════════════════════════════════
# CHECK 1: API keys, tokens, and secrets
# ══════════════════════════════════════════════════════════════════
# Patterns that match common secret formats:
#   - AWS keys (AKIA...)
#   - Generic API key/token assignments
#   - Bearer tokens
#   - Private keys
#   - Connection strings with passwords

SECRET_PATTERNS=(
    'AKIA[0-9A-Z]{16}'                          # AWS access key IDs
    '["\x27]sk[-_]live[-_][a-zA-Z0-9]{20,}'     # Stripe live secret keys
    '["\x27]sk[-_]test[-_][a-zA-Z0-9]{20,}'     # Stripe test keys
    'ghp_[a-zA-Z0-9]{36}'                       # GitHub personal access tokens
    'gho_[a-zA-Z0-9]{36}'                       # GitHub OAuth tokens
    'github_pat_[a-zA-Z0-9_]{80,}'              # GitHub fine-grained PATs
    'Bearer\s+[a-zA-Z0-9_\-\.]{20,}'           # Bearer tokens
    '-----BEGIN\s+(RSA|DSA|EC|OPENSSH)\s+PRIVATE\s+KEY-----'  # Private keys
    'api[_-]?key\s*[:=]\s*["\x27][a-zA-Z0-9_\-]{16,}'        # Generic API key assignments
    'api[_-]?secret\s*[:=]\s*["\x27][a-zA-Z0-9_\-]{16,}'     # Generic API secret assignments
    'token\s*[:=]\s*["\x27][a-zA-Z0-9_\-\.]{20,}'            # Generic token assignments
)

for file in $CHANGED_FILES; do
    # Skip binary files
    if file "$file" 2>/dev/null | grep -q "binary\|image\|PDF\|zip\|xlsx"; then
        continue
    fi
    [ -f "$file" ] || continue

    for pattern in "${SECRET_PATTERNS[@]}"; do
        matches=$(grep -nE "$pattern" "$file" 2>/dev/null)
        if [ -n "$matches" ]; then
            echo -e "${RED}${BOLD}BLOCKED — Possible secret detected${RESET}"
            echo -e "  File:    ${YELLOW}$file${RESET}"
            echo -e "  Pattern: $pattern"
            echo "$matches" | head -3 | while read line; do
                echo -e "  ${RED}→ $line${RESET}"
            done
            echo ""
            BLOCKED=1
        fi
    done
done

# ══════════════════════════════════════════════════════════════════
# CHECK 2: Hardcoded passwords
# ══════════════════════════════════════════════════════════════════
# Looks for password = "...", passwd, pwd assignments with actual values
# (not empty strings or placeholders).

PASSWORD_PATTERNS=(
    'password\s*[:=]\s*["\x27][^"\x27]{4,}'
    'passwd\s*[:=]\s*["\x27][^"\x27]{4,}'
    'pwd\s*[:=]\s*["\x27][^"\x27]{4,}'
    'secret\s*[:=]\s*["\x27][^"\x27]{8,}'
    'DB_PASSWORD\s*=\s*["\x27]?[a-zA-Z0-9]'
    'DATABASE_URL\s*=.*:\/\/[^:]+:[^@]+@'
)

for file in $CHANGED_FILES; do
    if file "$file" 2>/dev/null | grep -q "binary\|image\|PDF\|zip\|xlsx"; then
        continue
    fi
    [ -f "$file" ] || continue

    for pattern in "${PASSWORD_PATTERNS[@]}"; do
        matches=$(grep -niE "$pattern" "$file" 2>/dev/null)
        if [ -n "$matches" ]; then
            echo -e "${RED}${BOLD}BLOCKED — Possible hardcoded password${RESET}"
            echo -e "  File:    ${YELLOW}$file${RESET}"
            echo "$matches" | head -3 | while read line; do
                echo -e "  ${RED}→ $line${RESET}"
            done
            echo ""
            BLOCKED=1
        fi
    done
done

# ══════════════════════════════════════════════════════════════════
# CHECK 3: Sensitive personal data
# ══════════════════════════════════════════════════════════════════
# Catches things that look like SSNs, credit card numbers, phone
# numbers in certain formats. Conservative patterns to reduce
# false positives.

PII_PATTERNS=(
    '\b[0-9]{3}-[0-9]{2}-[0-9]{4}\b'                          # SSN format (XXX-XX-XXXX)
    '\b[0-9]{9}\b'                                              # SSN without dashes (9 digits)
    '\b(4[0-9]{12}([0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13}|6(011|5[0-9]{2})[0-9]{12})\b'  # Credit card numbers
    '\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}\b'     # Email addresses
)

PII_NAMES=(
    "SSN (XXX-XX-XXXX)"
    "SSN (9 digits)"
    "Credit card number"
    "Email address"
)

# Only check non-config, non-HTML files for PII (HTML will have
# false positives from mailto links, analytics IDs, etc.)
for file in $CHANGED_FILES; do
    if file "$file" 2>/dev/null | grep -q "binary\|image\|PDF\|zip\|xlsx"; then
        continue
    fi
    [ -f "$file" ] || continue

    # Skip files where these patterns are expected
    case "$file" in
        *.html|*.css|*.md|*.yml|*.yaml|*.json) continue ;;
    esac

    for i in "${!PII_PATTERNS[@]}"; do
        pattern="${PII_PATTERNS[$i]}"
        label="${PII_NAMES[$i]}"
        matches=$(grep -nE "$pattern" "$file" 2>/dev/null)
        if [ -n "$matches" ]; then
            echo -e "${RED}${BOLD}BLOCKED — Possible sensitive personal data${RESET}"
            echo -e "  File:    ${YELLOW}$file${RESET}"
            echo -e "  Type:    $label"
            echo "$matches" | head -3 | while read line; do
                echo -e "  ${RED}→ $line${RESET}"
            done
            echo ""
            BLOCKED=1
        fi
    done
done

# ══════════════════════════════════════════════════════════════════
# CHECK 4: Broken asset/file references
# ══════════════════════════════════════════════════════════════════
# Scans HTML files for href/src paths pointing to local files
# (not http/https/mailto/# links) and checks they exist on disk.

for file in $CHANGED_FILES; do
    [ -f "$file" ] || continue
    case "$file" in
        *.html) ;;
        *) continue ;;
    esac

    # Extract href="..." and src="..." values, filter to local paths
    refs=$(grep -oE '(href|src) *= *"[^"]*"' "$file" 2>/dev/null \
        | grep -oE '"[^"]*"' \
        | tr -d '"' \
        | grep -v '^http' \
        | grep -v '^//' \
        | grep -v '^#' \
        | grep -v '^mailto:' \
        | grep -v '^data:' \
        | grep -v '^javascript:' \
        | sort -u)

    for ref in $refs; do
        # Resolve relative to the HTML file's directory
        dir=$(dirname "$file")
        target="$dir/$ref"

        if [ ! -e "$target" ]; then
            echo -e "${YELLOW}${BOLD}WARNING — Broken asset reference${RESET}"
            echo -e "  File:      ${YELLOW}$file${RESET}"
            echo -e "  Reference: $ref"
            echo -e "  Expected:  $target (not found)"
            echo ""
            BLOCKED=1
        fi
    done
done

# ══════════════════════════════════════════════════════════════════
# Result
# ══════════════════════════════════════════════════════════════════

if [ "$BLOCKED" -eq 1 ]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "${RED}${BOLD}Push blocked.${RESET} Fix the issues above, or bypass with:"
    echo -e "  ${BOLD}git push --no-verify${RESET}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    exit 1
fi

exit 0
